# ไฟล์ตัวอย่าง (template) — commit ได้ เพราะไม่มี password จริง
#
# วิธีใช้: ก๊อปไฟล์นี้เป็น .env  ->  cp .env.example .env
#
# ค่าด้านล่างตรงกับ Postgres ที่มาจาก docker-compose (รัน `make db-up` หรือ
# `docker compose up -d`) — ใช้ได้ทันทีโดยไม่ต้องแก้
#
# ถ้าใช้ PostgreSQL ที่ติดตั้งในเครื่องเอง (ไม่ใช้ Docker):
#   เปลี่ยน "postgres" ตัวที่ 2 (หลัง : ) ให้เป็น password ของ user postgres ในเครื่องคุณ
#
# รูปแบบ: postgres://<user>:<password>@<host>:<port>/<dbname>?<options>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reslink_dev?sslmode=disable
